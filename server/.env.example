# Server
DATABASE_URL=postgres://user:pass@host:5432/chatbot_saas
JWT_SECRET=your-super-secret-jwt-key-change-this
PORT=3001
FRONTEND_URL=http://localhost:3000

# Meta WhatsApp (for webhook verification)
META_VERIFY_TOKEN=your-custom-verify-token-here
META_APP_SECRET=your-meta-app-secret

# Environment
NODE_ENV=development

# NOTE: OpenAI API keys are provided BY EACH TENANT
# in their dashboard settings. No shared key needed.
